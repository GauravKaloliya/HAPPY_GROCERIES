# Django Secret Key - Generate a secure random key for production
# You can use: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-production-secret-key-change-this-to-a-random-string

# Debug mode - Set to False in production
DEBUG=False

# Allowed hosts - Comma separated list
# Vercel automatically assigns a domain, so we use wildcard
ALLOWED_HOSTS=*.vercel.app,localhost,127.0.0.1

# CORS Settings
# Set to True to allow all origins (recommended for initial deployment)
CORS_ALLOW_ALL_ORIGINS=True

# If CORS_ALLOW_ALL_ORIGINS is False, specify allowed origins
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
