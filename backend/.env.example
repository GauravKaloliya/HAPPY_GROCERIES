# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ENVIRONMENT=development
RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require&channel_binding=require

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
AUTH_RATE_LIMIT_REQUESTS=25

# CSRF trusted origins (comma-separated, include frontend domains)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.onrender.com

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Frontend URL
FRONTEND_URL=http://localhost:5173
