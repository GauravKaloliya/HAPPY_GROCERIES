# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production

# Database Configuration
DATABASE_URL=postgres://user:password@host:port/database

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,api.happygroceries.shop

# CORS Origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://happygroceries.shop,https://www.happygroceries.shop,http://localhost:5173,http://localhost:3000

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Frontend URL
FRONTEND_URL=https://happygroceries.shop
