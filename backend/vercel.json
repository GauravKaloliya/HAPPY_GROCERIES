{
  "version": 2,
  "builds": [
    {
      "src": "happy_groceries/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "happy_groceries/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "happy_groceries.settings",
    "PYTHONPATH": "."
  },
  "functions": {
    "happy_groceries/wsgi.py": {
      "maxDuration": 30
    }
  }
}
