# Django Settings
SECRET_KEY=django-insecure-happygroceries-dev-key-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.production

# Database Configuration
# Option 1: Use DATABASE_URL (recommended for production)
# DATABASE_URL=postgres://user:password@host:port/database_name

# Option 2: Use individual database settings (for local development)
# DATABASE_NAME=happygroceries
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_SSL=false

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,api.happygroceries.shop

# CORS Origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://happygroceries.shop,https://www.happygroceries.shop,http://localhost:5173,http://localhost:3000

# Redis Configuration (for caching and JWT blacklisting)
REDIS_URL=redis://localhost:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Frontend URL (for password reset links, etc.)
FRONTEND_URL=https://happygroceries.shop

# Security Headers
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# SSL Settings (for production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
