<?xml version="1.0" encoding="UTF-8"?>
<header>
    <navbar>
        <logo>
            <text>🛒 Happy Groceries</text>
        </logo>
        <navigation>
            <menuItems>
                <item name="Home" href="index.html" active="false"/>
                <item name="Categories" href="categories.html" active="false"/>
                <item name="Shop" href="shop.html" active="false"/>
                <item name="Cart" href="cart.html" active="false"/>
                <item name="🎉 Offers" href="offers.html" active="false"/>
                <item name="About Us" href="about.html" active="false"/>
            </menuItems>
        </navigation>
        <actions>
            <themeToggle ariaLabel="Toggle dark mode" icon="🌙"/>
            <cartIcon emoji="🛒" counterId="cartCounter"/>
            <auth>
                <buttons>
                    <button name="Login" href="login.html" class="btn-login"/>
                    <button name="Sign Up" href="signup.html" class="btn-signup"/>
                </buttons>
                <profile style="display: none;">
                    <greeting text="Welcome, {{username}}! 👋"/>
                    <dropdown>
                        <item name="👤 View Profile" href="profile.html"/>
                        <item name="📦 My Orders" href="orders.html"/>
                        <item name="💖 Wishlist" href="wishlist.html"/>
                        <item name="⚙️ Settings" href="settings.html"/>
                        <separator/>
                        <item name="🚪 Logout" href="#" id="logoutBtn"/>
                    </dropdown>
                </profile>
            </auth>
        </actions>
    </navbar>
</header>
