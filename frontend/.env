# Happy Groceries Frontend Environment Configuration

# API Base URL
VITE_API_BASE_URL=http://localhost:8000/api

# CORS Origins - list of allowed origins for the API (JSON list format)
# This is used by the backend; frontend just needs the API URL above
VITE_CORS_ORIGINS=["https://happygroceries.shop","https://www.happygroceries.shop","http://localhost:8000","http://localhost:3000"]

# Application Settings
VITE_APP_NAME=Happy Groceries
VITE_APP_VERSION=1.0.0

# Timeouts (in milliseconds)
VITE_API_TIMEOUT=30000
VITE_CART_TIMEOUT=5000
